digraph Sprint {
  graph [goal = "Implement changes per .attractor/spec.md"]

  start [shape = "Mdiamond"]
  exit [shape = "Msquare"]
  setup [shape = "parallelogram", tool_command = "rm -rf .attractor/workspace && mkdir -p .attractor/workspace && cp .attractor/spec.md .attractor/workspace/spec.md && echo '# Progress' > .attractor/workspace/progress.md && git rev-parse HEAD > .attractor/workspace/base-commit"]
  plan [shape = "box", prompt = "Read .attractor/prompts/sprint/plan.md and follow the instructions.", llm_model = "opus"]
  audit [shape = "box", prompt = "Read .attractor/prompts/sprint/audit.md and follow the instructions.", llm_model = "opus"]
  implement [shape = "box", prompt = "Read .attractor/prompts/sprint/implement.md and follow the instructions."]
  review [shape = "box", prompt = "Read .attractor/prompts/sprint/review.md and follow the instructions.", llm_model = "opus"]
  test_plan [shape = "box", prompt = "Read .attractor/prompts/sprint/test-plan.md and follow the instructions.", llm_model = "opus"]
  test_fanout [shape = "component", max_parallel = "5"]
  test_a [shape = "box", prompt = "Read .attractor/prompts/sprint/test.md and follow the instructions."]
  test_b [shape = "box", prompt = "Read .attractor/prompts/sprint/test.md and follow the instructions."]
  test_c [shape = "box", prompt = "Read .attractor/prompts/sprint/test.md and follow the instructions."]
  test_d [shape = "box", prompt = "Read .attractor/prompts/sprint/test.md and follow the instructions."]
  test_e [shape = "box", prompt = "Read .attractor/prompts/sprint/test.md and follow the instructions."]
  test_merge [shape = "tripleoctagon"]
  fix [shape = "box", prompt = "Read .attractor/prompts/sprint/fix.md and follow the instructions."]
  wrapup [shape = "box", prompt = "Read .attractor/prompts/sprint/wrapup.md and follow the instructions."]

  start -> setup -> plan -> audit
  audit -> implement [condition = "context.audit_passed=true"]
  audit -> plan [condition = "context.audit_passed!=true"]
  implement -> implement [condition = "context.implementation_complete!=true"]
  implement -> review [condition = "context.implementation_complete=true"]
  review -> test_plan [condition = "context.review_passed=true"]
  review -> implement [condition = "context.review_passed!=true"]
  test_plan -> test_fanout
  test_fanout -> test_a -> test_merge
  test_fanout -> test_b -> test_merge
  test_fanout -> test_c -> test_merge
  test_fanout -> test_d -> test_merge
  test_fanout -> test_e -> test_merge
  test_merge -> wrapup [condition = "context.parallel.fail_count=0"]
  test_merge -> fix [condition = "context.parallel.fail_count!=0"]
  fix -> test_plan
  wrapup -> exit
}
