digraph G {
  graph [goal="Implement feature per .attractor/spec.md"]

  s [shape=Mdiamond]
  e [shape=Msquare]

  setup     [shape=box, prompt="Read .attractor/prompts/setup.md and follow the instructions."]
  implement [shape=box, prompt="Read .attractor/prompts/implement.md and follow the instructions."]
  review    [shape=box, prompt="Read .attractor/prompts/review.md and follow the instructions."]
  test      [shape=box, prompt="Read .attractor/prompts/test.md and follow the instructions."]
  fix       [shape=box, prompt="Read .attractor/prompts/fix.md and follow the instructions."]
  wrapup    [shape=box, prompt="Read .attractor/prompts/wrapup.md and follow the instructions."]

  s -> setup -> implement

  implement -> implement [condition="context.phase_complete!=true"]
  implement -> review    [condition="context.phase_complete=true"]

  review -> test      [condition="context.review_passed=true"]
  review -> implement [condition="context.review_passed!=true"]

  test -> wrapup [condition="context.tests_passed=true"]
  test -> fix    [condition="context.tests_passed!=true"]

  fix -> test
  wrapup -> e
}
